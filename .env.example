# ═══════════════════════════════════════════════════════════════
#  QT-AI 환경변수 템플릿 — .env.example
#  실제 값은 절대 커밋 금지. K8s Secret 또는 .env.local 사용.
#  gitleaks가 실제 시크릿 커밋을 CI에서 차단함.
# ═══════════════════════════════════════════════════════════════

# ── Anthropic (AI Service) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── JWT (Auth Service) ───────────────────────────────────────
# RS256 키쌍: openssl genrsa -out jwt_private.pem 2048
#             openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ACCESS_EXPIRY_SECONDS=1800
JWT_REFRESH_EXPIRY_SECONDS=1209600

# ── Google OAuth (Auth Service) ──────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_ME
# GOOGLE_REDIRECT_URI: 미사용 (POST idToken 방식, 04번 4.8 참조)

# ── MySQL (서비스별 별도 DB) ─────────────────────────────────
AUTH_DB_URL=jdbc:mysql://localhost:3306/auth_db?useSSL=false&allowPublicKeyRetrieval=true
AUTH_DB_USER=qtai
AUTH_DB_PASSWORD=REPLACE_ME

BIBLE_DB_URL=jdbc:mysql://localhost:3306/bible_db?useSSL=false&allowPublicKeyRetrieval=true
BIBLE_DB_USER=qtai
BIBLE_DB_PASSWORD=REPLACE_ME

AI_DB_URL=mysql+aiomysql://qtai:REPLACE_ME@localhost:3306/ai_db
JOURNAL_DB_URL=jdbc:mysql://localhost:3306/journal_db?useSSL=false
JOURNAL_DB_USER=qtai
JOURNAL_DB_PASSWORD=REPLACE_ME

# ── Redis ────────────────────────────────────────────────────
# Redis-WS : Auth refresh blacklist + BFF WS 세션 레지스트리
REDIS_WS_URL=redis://localhost:6379/0
# Redis-Cache : Bible passage 24h TTL
REDIS_CACHE_URL=redis://localhost:6379/1
# Redis-AI : AI 세션 캐시
REDIS_AI_URL=redis://localhost:6379/2

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8086

# ── ChromaDB (AI Service) ────────────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
LOKI_URL=http://localhost:3100
PROMETHEUS_SCRAPE_PORT=8080

# ── K8s / Helm (개발·배포 시 참고) ──────────────────────────
K8S_NAMESPACE=qtai
HELM_RELEASE_NAME=qtai
DOCKER_REGISTRY=ghcr.io/tae0072
IMAGE_TAG=latest
# Gateway CORS (prod: 실제 도메인으로 교체)
CORS_ALLOWED_ORIGINS=https://qtai.app

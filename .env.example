# QT-AI 환경 변수 placeholder (모노레포 루트)
# 실제 값은 .env (gitignore됨) 또는 K8s Secret로 주입
# 04번 § 11.2 + 03번 § 11.2 4계층 시크릿 방어

# === 공통 ===
ENVIRONMENT=dev
LOG_LEVEL=INFO

# === Database (각 service는 자기 schema만 접근) ===
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USERNAME=qtai
MYSQL_PASSWORD=<YOUR_PASSWORD>

# === Redis ===
REDIS_CACHE_HOST=redis-cache
REDIS_CACHE_PORT=6379
REDIS_WS_HOST=redis-ws
REDIS_WS_PORT=6379

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
SCHEMA_REGISTRY_URL=http://schema-registry:8080/apis/registry/v2

# === ChromaDB (AI Service 전용) ===
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# === JWT (Auth Service 전용) ===
JWT_PRIVATE_KEY_PATH=/etc/qtai/jwt/private.pem
JWT_PUBLIC_KEY_PATH=/etc/qtai/jwt/public.pem

# === Anthropic Claude API (AI Service 전용) ===
ANTHROPIC_API_KEY=<YOUR_KEY>
ANTHROPIC_MODEL=claude-sonnet-4-7-20251101

# === Google OAuth (Auth Service 전용) ===
GOOGLE_OAUTH_CLIENT_ID=<YOUR_CLIENT_ID>

# === Observability ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# 각 service 디렉토리에도 service별 .env.example 추가 예정 (W1)

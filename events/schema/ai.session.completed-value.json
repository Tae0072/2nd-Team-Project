{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ai.session.completed-value",
  "title": "AiSessionCompletedEvent",
  "description": "AI 대화 세션 완료 이벤트 — topic: ai.session.completed",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "schemaSubject", "occurredAt", "traceId", "producerService", "idempotencyKey", "data"],
  "properties": {
    "eventId":        { "type": "string", "description": "ULID 메시지 식별자 (예: evt_01HZX...)" },
    "eventType":      { "type": "string", "const": "ai.session.completed" },
    "eventVersion":   { "type": "integer", "minimum": 1, "example": 1 },
    "schemaSubject":  { "type": "string", "const": "ai.session.completed-value" },
    "occurredAt":     { "type": "string", "format": "date-time" },
    "traceId":        { "type": "string", "description": "분산 트레이싱 propagation" },
    "producerService":{ "type": "string", "const": "ai-service" },
    "idempotencyKey": { "type": "string", "description": "ai.session.completed:{sessionId}" },
    "data": {
      "type": "object",
      "required": ["sessionId", "userId", "qtDate", "passage", "finalStep", "summary"],
      "properties": {
        "sessionId":  { "type": "integer", "description": "AI_SESSIONS.id" },
        "userId":     { "type": "integer", "description": "Auth users.id 참조" },
        "qtDate":     { "type": "string", "format": "date", "description": "오늘 QT 날짜" },
        "passage": {
          "type": "object",
          "required": ["bookId", "bookCode", "chapter", "verseStart", "verseEnd"],
          "properties": {
            "bookId":   { "type": "integer" },
            "bookCode": { "type": "string", "example": "GEN" },
            "chapter":  { "type": "integer" },
            "verseStart": { "type": "integer" },
            "verseEnd":   { "type": "integer" }
          }
        },
        "finalStep":  { "type": "string", "enum": ["A", "B", "C", "D"] },
        "summary":    { "type": "string", "description": "세션 종료 시 자동 생성 요약" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ai.session.completed-value",
  "title": "AiSessionCompletedEvent",
  "description": "AI 큐티 세션 완료 이벤트 — topic: ai.session.completed",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "idempotencyKey", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "AI_SESSION_COMPLETED" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "idempotencyKey": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["sessionId", "userId", "finalStage"],
      "properties": {
        "sessionId": { "type": "integer" },
        "userId": { "type": "integer" },
        "book": { "type": "string" },
        "chapter": { "type": "integer" },
        "verse": { "type": "integer" },
        "finalStage": { "type": "string", "enum": ["D"] },
        "totalTurns": { "type": "integer" },
        "totalTokens": { "type": "integer" }
      }
    }
  }
}
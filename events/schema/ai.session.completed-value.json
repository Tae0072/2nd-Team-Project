{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ai.session.completed-value",
  "description": "AI 큐티 세션 4단계 완료 이벤트 (03번 § 6.1 + 02번 § 6.1).",
  "type": "object",
  "required": [
    "eventId", "eventType", "eventVersion", "schemaSubject",
    "idempotencyKey", "occurredAt", "traceId", "producerService", "data"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "이벤트 고유 ID (UUID v4 또는 ULID)"
    },
    "eventType": {
      "type": "string",
      "const": "ai.session.completed",
      "description": "이벤트 타입 (Kafka topic 명과 동일)"
    },
    "eventVersion": {
      "type": "string",
      "pattern": "^v\\d+$",
      "description": "이벤트 schema 버전 (예: v1)"
    },
    "schemaSubject": {
      "type": "string",
      "const": "ai.session.completed-value",
      "description": "Schema Registry subject 명"
    },
    "idempotencyKey": {
      "type": "string",
      "pattern": "^ai\\.session\\.completed:[0-9]+$",
      "description": "멱등성 키 — DB UNIQUE 제약과 함께 중복 처리 차단 (02번 § 8.3 + ADR-0007)"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "이벤트 발생 시각 (ISO 8601)"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$",
      "description": "W3C Trace Context trace_id (분산 추적용)"
    },
    "producerService": {
      "type": "string",
      "enum": ["auth-service", "bible-service", "ai-service", "journal-service", "bff-aggregator", "gateway"],
      "description": "이벤트 발행 서비스명"
    },
    "data": {
      "type": "object",
      "required": ["sessionId", "userId", "passage", "completedAt", "journalDraft"],
      "additionalProperties": false,
      "properties": {
        "sessionId": { "type": "integer", "minimum": 1 },
        "userId": { "type": "integer", "minimum": 1 },
        "passage": {
          "type": "object",
          "required": ["bookCode", "chapter", "verse"],
          "properties": {
            "bookCode": { "type": "string", "pattern": "^[A-Z0-9]{3}$" },
            "chapter": { "type": "integer", "minimum": 1 },
            "verse": { "type": "integer", "minimum": 1 }
          }
        },
        "completedAt": { "type": "string", "format": "date-time" },
        "journalDraft": {
          "type": "object",
          "required": ["title", "content"],
          "properties": {
            "title": { "type": "string", "minLength": 1, "maxLength": 200 },
            "content": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
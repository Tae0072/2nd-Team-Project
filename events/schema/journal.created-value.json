{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "journal.created-value",
  "title": "JournalCreatedEvent",
  "description": "오늘 QT 묵상 노트 DRAFT 생성 이벤트 — topic: journal.created",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "schemaSubject", "occurredAt", "traceId", "producerService", "idempotencyKey", "data"],
  "properties": {
    "eventId":        { "type": "string" },
    "eventType":      { "type": "string", "const": "journal.created" },
    "eventVersion":   { "type": "integer", "minimum": 1 },
    "schemaSubject":  { "type": "string", "const": "journal.created-value" },
    "occurredAt":     { "type": "string", "format": "date-time" },
    "traceId":        { "type": "string" },
    "producerService":{ "type": "string", "const": "bible-service" },
    "idempotencyKey": { "type": "string", "description": "journal.created:{journalId}" },
    "data": {
      "type": "object",
      "required": ["journalId", "userId", "qtDate", "passage", "createdAt"],
      "properties": {
        "journalId":  { "type": "integer" },
        "userId":     { "type": "integer" },
        "qtDate":     { "type": "string", "format": "date" },
        "passage": {
          "type": "object",
          "required": ["bookCode", "chapter", "verseStart", "verseEnd"],
          "properties": {
            "bookCode": { "type": "string" },
            "chapter":  { "type": "integer" },
            "verseStart": { "type": "integer" },
            "verseEnd":   { "type": "integer" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

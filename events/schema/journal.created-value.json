{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "journal.created-value",
  "title": "JournalCreatedEvent",
  "description": "묵상 노트 발행 이벤트 — Kafka topic: journal.created",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "idempotencyKey", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid", "description": "이벤트 고유 ID" },
    "eventType": { "type": "string", "const": "JOURNAL_CREATED" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "idempotencyKey": { "type": "string", "description": "Kafka 컨슈머 멱등성 키" },
    "payload": {
      "type": "object",
      "required": ["journalId", "userId", "title", "book", "chapter", "verse"],
      "properties": {
        "journalId": { "type": "integer" },
        "userId": { "type": "integer" },
        "title": { "type": "string" },
        "book": { "type": "string" },
        "chapter": { "type": "integer" },
        "verse": { "type": "integer" },
        "sessionId": { "type": "integer", "nullable": true }
      }
    }
  }
}
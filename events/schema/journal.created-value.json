{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "journal.created-value",
  "description": "묵상 노트 생성 이벤트 (04번 § 7.3 + ADR-0004).",
  "type": "object",
  "required": [
    "eventId", "eventType", "eventVersion", "schemaSubject",
    "idempotencyKey", "occurredAt", "traceId", "producerService", "data"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
      "description": "이벤트 고유 ID (UUID v4, RFC 4122)"
    },
    "eventType": {
      "type": "string",
      "const": "journal.created",
      "description": "이벤트 타입 (Kafka topic 명과 동일)"
    },
    "eventVersion": {
      "type": "string",
      "pattern": "^v\\d+$",
      "description": "이벤트 schema 버전 (예: v1)"
    },
    "schemaSubject": {
      "type": "string",
      "const": "journal.created-value",
      "description": "Schema Registry subject 명"
    },
    "idempotencyKey": {
      "type": "string",
      "pattern": "^journal\\.created:[0-9]+$",
      "description": "멱등성 키 — DB UNIQUE 제약과 함께 중복 처리 차단 (02번 § 8.3 + ADR-0007)"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "이벤트 발생 시각 (ISO 8601)"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$",
      "description": "W3C Trace Context trace_id (분산 추적용)"
    },
    "producerService": {
      "type": "string",
      "enum": ["auth-service", "bible-service", "ai-service", "journal-service", "bff-aggregator", "gateway"],
      "description": "이벤트 발행 서비스명"
    },
    "data": {
      "type": "object",
      "required": ["journalId", "userId", "title", "content", "status", "createdAt"],
      "additionalProperties": false,
      "properties": {
        "journalId": { "type": "integer", "minimum": 1 },
        "userId": { "type": "integer", "minimum": 1 },
        "aiSessionId": { "type": ["integer", "null"], "minimum": 1, "description": "AI 자동 생성 시 sessionId, 사용자 직접 작성 시 null" },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "content": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
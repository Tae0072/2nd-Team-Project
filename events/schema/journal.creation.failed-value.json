{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "journal.creation.failed-value",
  "title": "JournalCreationFailedEvent",
  "description": "오늘 QT 묵상 노트 생성/AI 요약 첨부 영구 실패 이벤트 (Saga 보상) — topic: journal.creation.failed",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "schemaSubject", "occurredAt", "traceId", "producerService", "idempotencyKey", "data"],
  "properties": {
    "eventId":        { "type": "string" },
    "eventType":      { "type": "string", "const": "journal.creation.failed" },
    "eventVersion":   { "type": "integer", "minimum": 1 },
    "schemaSubject":  { "type": "string", "const": "journal.creation.failed-value" },
    "occurredAt":     { "type": "string", "format": "date-time" },
    "traceId":        { "type": "string" },
    "producerService":{ "type": "string", "const": "bible-service" },
    "idempotencyKey": { "type": "string", "description": "journal.creation.failed:{sessionId}" },
    "data": {
      "type": "object",
      "required": ["sessionId", "originalIdempotencyKey", "error", "failedAt"],
      "properties": {
        "sessionId":              { "type": "integer" },
        "originalIdempotencyKey": { "type": "string" },
        "error":                  { "type": "string" },
        "failedAt":               { "type": "string", "format": "date-time" }
      }
    }
  }
}

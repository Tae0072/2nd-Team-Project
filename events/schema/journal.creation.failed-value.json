{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "journal.creation.failed-value",
  "title": "JournalCreationFailedEvent",
  "description": "묵상 노트 발행 실패 Saga 보상 이벤트 — topic: journal.creation.failed",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "idempotencyKey", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "JOURNAL_CREATION_FAILED" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "idempotencyKey": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["journalId", "userId", "reason"],
      "properties": {
        "journalId": { "type": "integer" },
        "userId": { "type": "integer" },
        "reason": { "type": "string", "description": "실패 원인 코드" },
        "compensationTarget": {
          "type": "string",
          "enum": ["AI_SERVICE", "JOURNAL_SERVICE"],
          "description": "보상 대상 서비스"
        }
      }
    }
  }
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "journal.deleted-value",
  "title": "JournalDeletedEvent",
  "description": "묵상 노트 삭제(Soft Delete) 이벤트 — topic: journal.deleted",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "schemaSubject", "occurredAt", "traceId", "producerService", "idempotencyKey", "data"],
  "properties": {
    "eventId":        { "type": "string" },
    "eventType":      { "type": "string", "const": "journal.deleted" },
    "eventVersion":   { "type": "integer", "minimum": 1 },
    "schemaSubject":  { "type": "string", "const": "journal.deleted-value" },
    "occurredAt":     { "type": "string", "format": "date-time" },
    "traceId":        { "type": "string" },
    "producerService":{ "type": "string", "const": "bible-service" },
    "idempotencyKey": { "type": "string", "description": "journal.delete:{journalId}:{epochMs}" },
    "data": {
      "type": "object",
      "required": ["journalId", "deletedAt"],
      "properties": {
        "journalId":  { "type": "integer" },
        "deletedAt":  { "type": "string", "format": "date-time" }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "journal.updated-value",
  "title": "JournalUpdatedEvent",
  "description": "묵상 노트 수정 이벤트 — Kafka topic: journal.updated",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "idempotencyKey", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "JOURNAL_UPDATED" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "idempotencyKey": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["journalId", "userId"],
      "properties": {
        "journalId": { "type": "integer" },
        "userId": { "type": "integer" },
        "title": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
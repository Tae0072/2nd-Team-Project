{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "notification.requested-value",
  "title": "NotificationRequestedEvent",
  "description": "실시간 알림 요청 이벤트 — topic: notification.requested",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "schemaSubject", "occurredAt", "traceId", "producerService", "idempotencyKey", "data"],
  "properties": {
    "eventId":        { "type": "string" },
    "eventType":      { "type": "string", "const": "notification.requested" },
    "eventVersion":   { "type": "integer", "minimum": 1 },
    "schemaSubject":  { "type": "string", "const": "notification.requested-value" },
    "occurredAt":     { "type": "string", "format": "date-time" },
    "traceId":        { "type": "string" },
    "producerService":{ "type": "string", "description": "발행 서비스명" },
    "idempotencyKey": { "type": "string", "description": "{type}:{userId}:{occurredAt}" },
    "data": {
      "type": "object",
      "required": ["userId", "type", "payload"],
      "properties": {
        "userId": { "type": "integer" },
        "type":   {
          "type": "string",
          "enum": ["JOURNAL_AI_DRAFT_READY", "JOURNAL_PUBLISHED", "STREAK_MILESTONE"],
          "description": "04번 10.4 참조. 확장 시 Schema Registry BACKWARD 호환 신규 enum 추가"
        },
        "payload": {
          "type": "object",
          "description": "type별 metadata. JOURNAL_AI_DRAFT_READY: {journalId, aiSessionId}"
        }
      }
    }
  }
}

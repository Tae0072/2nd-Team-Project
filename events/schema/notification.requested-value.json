{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "notification.requested-value",
  "title": "NotificationRequestedEvent",
  "description": "알림 발송 요청 이벤트 — topic: notification.requested",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "idempotencyKey", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "NOTIFICATION_REQUESTED" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "idempotencyKey": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["userId", "notificationType", "title", "body"],
      "properties": {
        "userId": { "type": "integer" },
        "notificationType": {
          "type": "string",
          "enum": ["JOURNAL_PUBLISHED", "AI_SESSION_COMPLETED", "SYSTEM"]
        },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "referenceId": { "type": "integer", "nullable": true }
      }
    }
  }
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user.activity.tracked-value",
  "title": "UserActivityTrackedEvent",
  "description": "사용자 활동 추적 이벤트 — topic: user.activity.tracked",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "schemaSubject", "occurredAt", "traceId", "producerService", "idempotencyKey", "data"],
  "properties": {
    "eventId":        { "type": "string" },
    "eventType":      { "type": "string", "const": "user.activity.tracked" },
    "eventVersion":   { "type": "integer", "minimum": 1 },
    "schemaSubject":  { "type": "string", "const": "user.activity.tracked-value" },
    "occurredAt":     { "type": "string", "format": "date-time" },
    "traceId":        { "type": "string" },
    "producerService":{ "type": "string", "const": "bff-aggregator" },
    "idempotencyKey": { "type": "string", "description": "read.passage:{userId}:{book}:{ch}:{v}:{epochMinute}" },
    "data": {
      "type": "object",
      "required": ["userId", "activityType", "passage", "occurredAt"],
      "properties": {
        "userId":       { "type": "integer" },
        "activityType": { "type": "string", "enum": ["READ_PASSAGE"] },
        "passage": {
          "type": "object",
          "required": ["bookCode", "chapter", "verse"],
          "properties": {
            "bookCode": { "type": "string" },
            "chapter":  { "type": "integer" },
            "verse":    { "type": "integer" }
          }
        },
        "occurredAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

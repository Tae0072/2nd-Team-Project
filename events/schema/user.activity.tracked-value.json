{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user.activity.tracked-value",
  "title": "UserActivityTrackedEvent",
  "description": "사용자 활동 추적 이벤트 — topic: user.activity.tracked",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "idempotencyKey", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "USER_ACTIVITY_TRACKED" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "idempotencyKey": {
      "type": "string",
      "description": "read.passage:{user_id}:{book}:{ch}:{v}:{epoch_minute} 형식",
      "example": "read.passage:1001:JHN:3:16:28562400"
    },
    "payload": {
      "type": "object",
      "required": ["userId", "activityType"],
      "properties": {
        "userId": { "type": "integer" },
        "activityType": {
          "type": "string",
          "enum": ["READ_PASSAGE", "START_SESSION", "COMPLETE_SESSION", "PUBLISH_JOURNAL"]
        },
        "book": { "type": "string" },
        "chapter": { "type": "integer" },
        "verse": { "type": "integer" },
        "sessionId": { "type": "integer" },
        "journalId": { "type": "integer" }
      }
    }
  }
}
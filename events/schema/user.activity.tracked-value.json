{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "user.activity.tracked-value",
  "description": "사용자 구절 읽기 추적 이벤트 (02번 § 6.1 + 04번 § 4.10).",
  "type": "object",
  "required": [
    "eventId", "eventType", "eventVersion", "schemaSubject",
    "idempotencyKey", "occurredAt", "traceId", "producerService", "data"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "이벤트 고유 ID (UUID v4 또는 ULID)"
    },
    "eventType": {
      "type": "string",
      "const": "user.activity.tracked",
      "description": "이벤트 타입 (Kafka topic 명과 동일)"
    },
    "eventVersion": {
      "type": "string",
      "pattern": "^v\\d+$",
      "description": "이벤트 schema 버전 (예: v1)"
    },
    "schemaSubject": {
      "type": "string",
      "const": "user.activity.tracked-value",
      "description": "Schema Registry subject 명"
    },
    "idempotencyKey": {
      "type": "string",
      "pattern": "^read\\.passage:[0-9]+:[A-Z0-9]{3}:[0-9]+:[0-9]+:[0-9]+$",
      "description": "멱등성 키 — DB UNIQUE 제약과 함께 중복 처리 차단 (02번 § 8.3 + ADR-0007)"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "이벤트 발생 시각 (ISO 8601)"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$",
      "description": "W3C Trace Context trace_id (분산 추적용)"
    },
    "producerService": {
      "type": "string",
      "enum": ["auth-service", "bible-service", "ai-service", "journal-service", "bff-aggregator", "gateway"],
      "description": "이벤트 발행 서비스명"
    },
    "data": {
      "type": "object",
      "required": ["type", "userId", "passage", "readAt"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "read.passage" },
        "userId": { "type": "integer", "minimum": 1 },
        "passage": {
          "type": "object",
          "required": ["bookCode", "chapter", "verse"],
          "properties": {
            "bookCode": { "type": "string", "pattern": "^[A-Z0-9]{3}$" },
            "chapter": { "type": "integer", "minimum": 1 },
            "verse": { "type": "integer", "minimum": 1 }
          }
        },
        "readAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
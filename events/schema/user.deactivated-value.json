{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user.deactivated-value",
  "title": "UserDeactivatedEvent",
  "description": "회원 탈퇴 이벤트 — topic: user.deactivated",
  "type": "object",
  "required": ["eventId", "eventType", "eventVersion", "schemaSubject", "occurredAt", "traceId", "producerService", "idempotencyKey", "data"],
  "properties": {
    "eventId":        { "type": "string" },
    "eventType":      { "type": "string", "const": "user.deactivated" },
    "eventVersion":   { "type": "integer", "minimum": 1 },
    "schemaSubject":  { "type": "string", "const": "user.deactivated-value" },
    "occurredAt":     { "type": "string", "format": "date-time" },
    "traceId":        { "type": "string" },
    "producerService":{ "type": "string", "const": "auth-service" },
    "idempotencyKey": { "type": "string", "description": "user.deactivated:{userId}" },
    "data": {
      "type": "object",
      "required": ["userId", "deactivatedAt"],
      "properties": {
        "userId":        { "type": "integer" },
        "deactivatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}

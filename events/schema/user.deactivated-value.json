{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "user.deactivated-value",
  "description": "사용자 탈퇴 이벤트 (02번 § 2.2.1 마스킹 + 04번 § 4.7 + ADR-0010).",
  "type": "object",
  "required": [
    "eventId", "eventType", "eventVersion", "schemaSubject",
    "idempotencyKey", "occurredAt", "traceId", "producerService", "data"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
      "description": "이벤트 고유 ID (UUID v4, RFC 4122)"
    },
    "eventType": {
      "type": "string",
      "const": "user.deactivated",
      "description": "이벤트 타입 (Kafka topic 명과 동일)"
    },
    "eventVersion": {
      "type": "string",
      "pattern": "^v\\d+$",
      "description": "이벤트 schema 버전 (예: v1)"
    },
    "schemaSubject": {
      "type": "string",
      "const": "user.deactivated-value",
      "description": "Schema Registry subject 명"
    },
    "idempotencyKey": {
      "type": "string",
      "pattern": "^user\\.deactivated:[0-9]+$",
      "description": "멱등성 키 — DB UNIQUE 제약과 함께 중복 처리 차단 (02번 § 8.3 + ADR-0007)"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "이벤트 발생 시각 (ISO 8601)"
    },
    "traceId": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$",
      "description": "W3C Trace Context trace_id (분산 추적용)"
    },
    "producerService": {
      "type": "string",
      "enum": ["auth-service", "bible-service", "ai-service", "journal-service", "bff-aggregator", "gateway"],
      "description": "이벤트 발행 서비스명"
    },
    "data": {
      "type": "object",
      "required": ["userId", "deactivatedAt"],
      "additionalProperties": false,
      "properties": {
        "userId": { "type": "integer", "minimum": 1 },
        "deactivatedAt": { "type": "string", "format": "date-time" },
        "retentionPolicy": {
          "type": "object",
          "properties": {
            "journalRetainedDays": { "type": "integer", "minimum": 0 },
            "aiSessionStatus": { "type": "string", "const": "ABANDONED" }
          }
        }
      }
    }
  }
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "user.deactivated-value",
  "title": "UserDeactivatedEvent",
  "description": "회원 탈퇴 이벤트 — topic: user.deactivated",
  "type": "object",
  "required": ["eventId", "eventType", "occurredAt", "idempotencyKey", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "USER_DEACTIVATED" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "idempotencyKey": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["userId", "maskedEmail"],
      "properties": {
        "userId": { "type": "integer" },
        "maskedEmail": {
          "type": "string",
          "description": "u***@***.com 형식으로 마스킹된 이메일"
        },
        "deactivatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}